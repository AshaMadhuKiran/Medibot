# ---- LLM inference (Groq cloud API) ----
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=<key>
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Auth ----
# Secret used to sign session JWTs. Change this in production.
MEDIBOT_JWT_SECRET=change-me-to-a-long-random-string
MEDIBOT_TOKEN_TTL_MINUTES=120

# ---- Data locations (absolute or relative to repo root) ----
# Folder that holds the per-collection subfolders (general/, clinical/, ...)
MEDIBOT_DATA_DIR=../data
# SQLite database used by the SQL RAG chain
MEDIBOT_DB_PATH=../data/db/mediassist.db
# On-disk Qdrant storage (persists the ingested index between runs)
MEDIBOT_QDRANT_PATH=./qdrant_storage

# ---- Models ----
MEDIBOT_DENSE_MODEL=sentence-transformers/all-MiniLM-L6-v2
MEDIBOT_SPARSE_MODEL=Qdrant/bm25
MEDIBOT_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---- Retrieval tuning ----
MEDIBOT_RETRIEVE_TOP_K=10
MEDIBOT_RERANK_TOP_K=3
